{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "target": "marketing",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "/.well-known/apple-app-site-association",
          "headers": [
            { "key": "Content-Type", "value": "application/json" }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "/privacy.html",
          "destination": "/legal/privacy.html"
        },
        {
          "source": "/terms.html",
          "destination": "/legal/terms.html"
        },
        {
          "source": "/privacy",
          "destination": "/legal/privacy.html"
        },
        {
          "source": "/terms",
          "destination": "/legal/terms.html"
        },
        {
          "source": "/privacy/**",
          "destination": "/legal/privacy.html"
        },
        {
          "source": "/terms/**",
          "destination": "/legal/terms.html"
        },
        {
          "source": "/auth/**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "app",
      "public": "build/web",
      "ignore": [
        "firebase.json",
        "**/.*"
      ],
      "headers": [
        {
          "source": "**/*.@(js|wasm)",
          "headers": [
            { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" },
            { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" }
          ]
        }
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "loadout-precision-reloading",
          "appId": "1:1050892389392:android:7a78dfd09b356771d4ce95",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "loadout-precision-reloading",
          "appId": "1:1050892389392:ios:d839fab5d268e9f8d4ce95",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "loadout-precision-reloading",
          "configurations": {
            "android": "1:1050892389392:android:7a78dfd09b356771d4ce95",
            "ios": "1:1050892389392:ios:d839fab5d268e9f8d4ce95"
          }
        }
      }
    }
  }
}
